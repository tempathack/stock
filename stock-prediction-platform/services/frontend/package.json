{
  "name": "stock-prediction-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:prod": "playwright test --config=playwright.production.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:infra": "playwright test --config=playwright.infra.config.ts",
    "test:infra:grafana": "playwright test --config playwright.infra.config.ts --project=grafana",
    "test:infra:headed": "playwright test --config playwright.infra.config.ts --headed",
    "test:all": "npm run test:e2e && npm run test:infra"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.0",
    "@mui/x-data-grid": "^8.28.1",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.9",
    "echarts": "^5.5.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.2"
  }
}
