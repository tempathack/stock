# Template for stock-platform-secrets.
# Copy this file to secrets.yaml and replace base64 values with real credentials.
#
# To encode a value:  echo -n 'yourpassword' | base64
# To decode a value:  echo 'base64string' | base64 -d
#
# For production, use Sealed Secrets or an external secrets operator:
#   kubeseal --format yaml < secrets.yaml > sealed-secrets.yaml
#   kubectl apply -f sealed-secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: stock-platform-secrets
  namespace: storage
  labels:
    app.kubernetes.io/part-of: stock-prediction-platform
type: Opaque
data:
  # Admin password — echo -n 'CHANGEME' | base64
  POSTGRES_PASSWORD: Q0hBTkdFTUU=
  # Admin connection — echo -n 'postgresql://stockuser:CHANGEME@postgresql.storage.svc.cluster.local:5432/stockdb' | base64
  DATABASE_URL: Q0hBTkdFTUU=
  # Read-only — echo -n 'postgresql://stock_readonly:CHANGEME@postgresql.storage.svc.cluster.local:5432/stockdb' | base64
  DATABASE_URL_READONLY: Q0hBTkdFTUU=
  # Writer — echo -n 'postgresql://stock_writer:CHANGEME@postgresql.storage.svc.cluster.local:5432/stockdb' | base64
  DATABASE_URL_WRITER: Q0hBTkdFTUU=
  # RBAC role passwords — echo -n 'CHANGEME' | base64
  POSTGRES_READONLY_PASSWORD: Q0hBTkdFTUU=
  POSTGRES_WRITER_PASSWORD: Q0hBTkdFTUU=
  # FRED API key — echo -n 'your_fred_api_key_from_fred.stlouisfed.org' | base64
  FRED_API_KEY: Q0hBTkdFTUU=
