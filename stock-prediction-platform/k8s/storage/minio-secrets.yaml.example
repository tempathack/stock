# Template for minio-secrets.
# Copy this file to minio-secrets.yaml and replace base64 values with real credentials.
#
# To encode a value:  echo -n 'yourpassword' | base64
# To decode a value:  echo 'base64string' | base64 -d
#
# For production, use Sealed Secrets or an external secrets operator:
#   kubeseal --format yaml < minio-secrets.yaml > sealed-minio-secrets.yaml
#   kubectl apply -f sealed-minio-secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: minio-secrets
  namespace: storage
  labels:
    app: minio
    app.kubernetes.io/part-of: stock-prediction-platform
type: Opaque
data:
  # Root user — echo -n 'CHANGEME' | base64
  MINIO_ROOT_USER: Q0hBTkdFTUU=
  # Root password (16+ chars) — echo -n 'CHANGEME' | base64
  MINIO_ROOT_PASSWORD: Q0hBTkdFTUU=
