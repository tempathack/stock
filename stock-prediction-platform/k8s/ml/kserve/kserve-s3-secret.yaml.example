# KServe S3 Credentials Secret — Template
# =========================================
# Copy this file to kserve-s3-secret.yaml and replace placeholder base64 values
# with real credentials matching k8s/storage/minio-secrets.yaml.
#
# To encode: echo -n 'yourpassword' | base64
# To decode: echo 'base64string' | base64 -d
#
# WARNING: Do NOT commit kserve-s3-secret.yaml with real credentials to VCS.

apiVersion: v1
kind: Secret
metadata:
  name: kserve-s3-credentials
  namespace: ml
  labels:
    app: kserve
    app.kubernetes.io/part-of: stock-prediction-platform
  annotations:
    serving.kserve.io/s3-endpoint: minio.storage.svc.cluster.local:9000
    serving.kserve.io/s3-usehttps: "0"
    serving.kserve.io/s3-region: us-east-1
    serving.kserve.io/s3-verifyssl: "0"
type: Opaque
data:
  # Replace with base64-encoded MinIO access key (must match MINIO_ROOT_USER)
  AWS_ACCESS_KEY_ID: Q0hBTkdFTUU=
  # Replace with base64-encoded MinIO secret key (must match MINIO_ROOT_PASSWORD)
  AWS_SECRET_ACCESS_KEY: Q0hBTkdFTUU=
